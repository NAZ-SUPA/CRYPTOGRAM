<?xml version="1.0" encoding="utf-8"?>
<!--
    Default Keyboard Key Background:
    - Defines the visual shape and color for the standard keys on the custom in-game keyboard.
    - Uses a simple white fill with rounded corners and a light gray border.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- The solid color filling the interior of the key. -->
    <solid android:color="#FFFFFF" />

    <!-- Rounded corners to provide a soft, modern UI feel. -->
    <corners android:radius="8dp" />

    <!-- A thin border (stroke) to define the key's boundaries against the keyboard background. -->
    <stroke
        android:width="1dp"
        android:color="#D1D5DB" />
</shape>
