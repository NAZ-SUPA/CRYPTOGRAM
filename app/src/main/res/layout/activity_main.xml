<?xml version="1.0" encoding="utf-8"?>
<!--
    Root ConstraintLayout for the Splash Screen (MainActivity).
    ConstraintLayout allows for a flexible UI by positioning elements relative to each other and the parent.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#303240"
    tools:context=".MainActivity">

    <!--
        Welcome Label:
        - Displays the text "WELCOME TO".
        - Positioned near the top center of the screen with a significant top margin.
        - Uses a custom style '@style/welcome_to' for consistent typography.
    -->
    <TextView
        android:id="@+id/welcome_to"
        style="@style/welcome_to"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="200dp"
        android:gravity="center"
        android:text="@string/welcome_to"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!--
        Background Accent View 1:
        - A yellow vertical rectangle used for visual branding.
        - Positioned specifically behind the first 'R' in "CRYPTOGRAM".
        - Helps create the "highlighted character" aesthetic of a cipher.
    -->
    <View
        android:id="@+id/rectangle_2"
        android:layout_width="32dp"
        android:layout_height="92dp"
        android:layout_marginStart="32dp"
        android:layout_marginTop="40dp"
        android:background="@color/accent_yellow"
        app:layout_constraintBottom_toBottomOf="@+id/cryptogram"
        app:layout_constraintStart_toStartOf="@+id/cryptogram"
        app:layout_constraintTop_toTopOf="@+id/cryptogram" />

    <!--
        Background Accent View 2:
        - A yellow vertical rectangle used for visual branding.
        - Positioned specifically behind the second 'R' in "CRYPTOGRAM".
        - Mirrors rectangle_2 to complete the symmetrical brand design.
    -->
    <View
        android:id="@+id/rectangle_3"
        android:layout_width="32dp"
        android:layout_height="92dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="77dp"
        android:background="@color/accent_yellow"
        app:layout_constraintBottom_toBottomOf="@+id/cryptogram"
        app:layout_constraintEnd_toEndOf="@+id/cryptogram"
        app:layout_constraintTop_toTopOf="@+id/cryptogram" />

    <!--
        Main Brand Title:
        - Displays "CRYPTOGRAM" in large, stylized font.
        - Logic in MainActivity.java applies ForegroundColorSpan to specific letters.
        - Centered horizontally and placed below the welcome label.
    -->
    <TextView
        android:id="@+id/cryptogram"
        style="@style/cryptogram"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="@string/cryptogram"
        android:visibility="visible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.52"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/welcome_to" />

    <!--
        Cipher Numeric Pattern:
        - Displays a series of numbers beneath the title (e.g., "3 18 25...").
        - Reinforces the puzzle/cryptogram theme.
        - Uses letterSpacing to align roughly with the title letters above it.
    -->
    <TextView
        android:id="@+id/tv_cipher_numbers"
        style="@style/cipher_style"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="-8dp"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:letterSpacing="0.245"
        android:text="@string/cipher_numbers"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cryptogram" />

</androidx.constraintlayout.widget.ConstraintLayout>
