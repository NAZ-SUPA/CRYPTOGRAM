<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#303240"
    android:padding="24dp">

    <!--
        Settings Layout Logic:
        - This screen manages application-wide preferences.
        - @id/tv_title: The primary header for the settings context.
        - @id/notif_container: Implements a custom segmented toggle for notifications.
        - @id/font_box: Groups font-size scaling options into a cohesive card.
    -->

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:fontFamily="@font/iceberg"
        android:text="@string/settings_title"
        android:textColor="#FFFFFF"
        android:textSize="48sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!--
        Notification Toggle Section Logic:
        - This area allows the user to enable or disable push/in-game notifications.
        - The segmented control (MaterialCardView + LinearLayout) is visually toggled
          in Settings.java by updating the 'isSelected' property of the buttons.
    -->
    <TextView
        android:id="@+id/label_notif"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="52dp"
        android:fontFamily="@font/iceberg"
        android:text="@string/label_notifications"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/notif_container"
        android:layout_width="140dp"
        android:layout_height="40dp"
        android:layout_marginEnd="50dp"
        app:cardBackgroundColor="#2D303A"
        app:cardCornerRadius="100dp"
        app:cardElevation="0dp"
        app:strokeColor="#4A4D58"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="@id/label_notif"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/label_notif">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/toggle_on"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:fontFamily="@font/iceberg"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:text="@string/btn_on"
                android:textAllCaps="true"
                android:textColor="#303240"
                android:textSize="12sp"
                android:textStyle="bold"
                app:backgroundTint="#D1C4E9"
                app:cornerRadius="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/toggle_off"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:fontFamily="@font/iceberg"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:text="@string/btn_off"
                android:textAllCaps="true"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="0dp"
                tools:ignore="TouchTargetSizeCheck" />

            <!-- Vertical divider for visual separation -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#4A4D58" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!--
        Tutorial / Help Button:
        - Centrally located to provide the user with instructions on how to play the game.
    -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_how_to_play"
        android:layout_width="300dp"
        android:layout_height="55dp"
        android:layout_marginTop="35dp"
        android:fontFamily="@font/iceberg"
        android:text="@string/btn_how_to_play"
        android:textAllCaps="true"
        android:textColor="#3F51B5"
        android:textSize="22sp"
        android:textStyle="bold"
        app:backgroundTint="#FFFFFF"
        app:cornerRadius="30dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/label_notif" />

    <!--
        Font Size Configuration Card Logic:
        - Encapsulates the font-size selection UI.
        - The use of a MaterialCardView provides a clean, white background that makes
          the control group stand out from the dark theme.
    -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/font_box"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="35dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_how_to_play">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/iceberg"
                android:text="@string/select_font_size"
                android:textColor="#3F51B5"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- Row for the scaling presets: x1, x1.5, x2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:gravity="center"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/f_x1"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="45dp"
                    android:layout_height="100dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    android:text="@string/font_x1"
                    android:textColor="#3F51B5"
                    android:textSize="16sp"
                    app:backgroundTint="#D1C4E9"
                    app:cornerRadius="25dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/f_x15"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="45dp"
                    android:layout_height="100dp"
                    android:layout_marginHorizontal="35dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    android:text="@string/font_x15"
                    android:textColor="#3F51B5"
                    android:textSize="18sp"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="25dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/f_x2"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="45dp"
                    android:layout_height="100dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    android:text="@string/font_x2"
                    android:textColor="#3F51B5"
                    android:textSize="22sp"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="25dp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!--
        Navigation Button Logic:
        - Returns the user to the previous screen (Home/Levels/Game).
    -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_back_home"
        android:layout_width="148dp"
        android:layout_height="66dp"
        android:layout_marginBottom="250dp"
        android:fontFamily="@font/iceberg"
        android:text="@string/btn_home"
        android:textAllCaps="true"
        android:textColor="#3F51B5"
        android:textSize="20sp"
        app:backgroundTint="#FFFFFF"
        app:cornerRadius="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>