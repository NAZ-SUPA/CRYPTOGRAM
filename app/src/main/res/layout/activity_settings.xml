<?xml version="1.0" encoding="utf-8"?>
<!--
    Settings Activity Layout:
    - This screen allows users to manage app preferences such as notifications and font sizes.
    - Uses ConstraintLayout for a clean, organized arrangement of settings controls.
    - Dark theme background consistent with the overall app aesthetic.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#303240"
    android:padding="24dp">

    <!--
        Screen Title:
        - Large heading "SETTINGS" using the Iceberg font.
        - Centered at the top of the screen.
    -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:fontFamily="@font/iceberg"
        android:text="@string/settings_title"
        android:textColor="#FFFFFF"
        android:textSize="48sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!--
        Notifications Label:
        - Indicates the purpose of the adjacent toggle switch.
    -->
    <TextView
        android:id="@+id/label_notif"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="52dp"
        android:fontFamily="@font/iceberg"
        android:text="@string/label_notifications"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title"/>

    <!--
        Notification Toggle Container:
        - A rounded MaterialCardView used to house the ON/OFF toggle buttons.
        - Creates a segmented control visual effect.
    -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/notif_container"
        android:layout_width="140dp"
        android:layout_height="40dp"
        android:layout_marginEnd="50dp"
        app:cardBackgroundColor="#2D303A"
        app:cardCornerRadius="100dp"
        app:cardElevation="0dp"
        app:strokeColor="#4A4D58"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="@id/label_notif"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/label_notif">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <!--
                ON Toggle Button:
                - Highlighted when notifications are enabled.
            -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/toggle_on"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:fontFamily="@font/iceberg"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:text="@string/btn_on"
                android:textAllCaps="true"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                app:backgroundTint="#4A4D58"
                app:cornerRadius="0dp"/>

            <!--
                OFF Toggle Button:
                - Highlighted when notifications are disabled.
            -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/toggle_off"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:fontFamily="@font/iceberg"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:text="@string/btn_off"
                android:textAllCaps="true"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                app:backgroundTint="#4A4D58"
                app:cornerRadius="0dp"/>

            <!-- Small vertical divider between toggles -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#4A4D58"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!--
        How To Play Button:
        - Opens the instructional modal (HowToPlayFragment).
    -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_how_to_play"
        android:layout_width="300dp"
        android:layout_height="55dp"
        android:layout_marginTop="35dp"
        android:fontFamily="@font/iceberg"
        android:text="@string/btn_how_to_play"
        android:textAllCaps="true"
        android:textColor="#3F51B5"
        android:textSize="22sp"
        android:textStyle="bold"
        app:backgroundTint="#FFFFFF"
        app:cornerRadius="30dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/label_notif"/>

    <!--
        Font Size Selection Card:
        - A white card containing options to scale the game text.
    -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/font_box"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="35dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_how_to_play">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Font Selection Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/iceberg"
                android:text="@string/select_font_size"
                android:textColor="#3F51B5"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <!-- Row of font size options (x1, x1.5, x2) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- Small font option -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/f_x1"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="45dp"
                    android:layout_height="100dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    android:text="@string/font_x1"
                    android:textColor="#3F51B5"
                    android:textSize="16sp"
                    app:backgroundTint="#D1C4E9"
                    app:cornerRadius="25dp"/>

                <!-- Medium font option -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/f_x15"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="45dp"
                    android:layout_height="100dp"
                    android:layout_marginHorizontal="35dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    android:text="@string/font_x15"
                    android:textColor="#3F51B5"
                    android:textSize="18sp"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="25dp"/>

                <!-- Large font option -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/f_x2"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="45dp"
                    android:layout_height="100dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    android:text="@string/font_x2"
                    android:textColor="#3F51B5"
                    android:textSize="22sp"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="25dp"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!--
        Email Support Button:
        - Triggers a mailto intent to the developer.
    -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_email"
        android:layout_width="148dp"
        android:layout_height="66dp"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/iceberg"
        android:text="@string/btn_email"
        android:textAllCaps="true"
        android:textColor="#3F51B5"
        android:textSize="20sp"
        app:backgroundTint="#FFFFFF"
        app:cornerRadius="30dp"
        app:layout_constraintTop_toBottomOf="@id/font_box"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btn_back_home"/>

    <!--
        Back to Home Button:
        - Returns the user to the main menu screen.
    -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_back_home"
        android:layout_width="148dp"
        android:layout_height="66dp"
        android:layout_marginBottom="100dp"
        android:fontFamily="@font/iceberg"
        android:text="@string/btn_home"
        android:textAllCaps="true"
        android:textColor="#3F51B5"
        android:textSize="20sp"
        app:backgroundTint="#FFFFFF"
        app:cornerRadius="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"/>

    <!--
        Fragment Container:
        - Used to host the HowToPlayFragment overlay.
        - Initially hidden (gone) until the instruction button is clicked.
    -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
