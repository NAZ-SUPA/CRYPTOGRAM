<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#303240"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:fontFamily="@font/iceberg"
        android:text="SETTINGS"
        android:textColor="#FFFFFF"
        android:textSize="48sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Notifications label -->

    <!-- Notification toggle container -->
    <TextView
        android:id="@+id/label_notif"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="44dp"
        android:layout_marginTop="48dp"
        android:fontFamily="@font/iceberg"
        android:text="NOTIFICATIONS"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/notif_container"
        android:layout_width="140dp"
        android:layout_height="40dp"
        android:layout_marginEnd="50dp"
        app:cardBackgroundColor="#2D303A"
        app:cardCornerRadius="100dp"
        app:cardElevation="0dp"
        app:strokeColor="#4A4D58"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="@id/label_notif"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/label_notif">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/toggle_on"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:fontFamily="@font/iceberg"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:text="ON"
                android:textAllCaps="true"
                android:textColor="#303240"
                android:textSize="12sp"
                android:textStyle="bold"
                app:backgroundTint="#D1C4E9"
                app:cornerRadius="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/toggle_off"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:fontFamily="@font/iceberg"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:text="OFF"
                android:textAllCaps="true"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="0dp" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#4A4D58" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- How to Play button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_how_to_play"
        android:layout_width="300dp"
        android:layout_height="55dp"
        android:layout_marginTop="35dp"
        android:fontFamily="@font/iceberg"
        android:text="HOW TO PLAY"
        android:textAllCaps="true"
        android:textColor="#3F51B5"
        android:textSize="22sp"
        android:textStyle="bold"
        app:backgroundTint="#FFFFFF"
        app:cornerRadius="30dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/label_notif"
        tools:layout_editor_absoluteX="24dp" />

    <!-- Font selection box -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/font_box"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="35dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_how_to_play"
        tools:layout_editor_absoluteX="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/iceberg"
                android:text="SELECT FONT SIZE"
                android:textColor="#3F51B5"
                android:textSize="22sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:gravity="center"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/f_x1"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="45dp"
                    android:layout_height="100dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    android:text="T\n-\nx1"
                    android:textColor="#3F51B5"
                    android:textSize="16sp"
                    app:backgroundTint="#D1C4E9"
                    app:cornerRadius="25dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/f_x15"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="45dp"
                    android:layout_height="100dp"
                    android:layout_marginHorizontal="35dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    android:text="T\n-\nx1.5"
                    android:textColor="#3F51B5"
                    android:textSize="18sp"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="25dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/f_x2"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="45dp"
                    android:layout_height="100dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    android:text="T\n-\nx2"
                    android:textColor="#3F51B5"
                    android:textSize="22sp"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="25dp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Home button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_back_home"
        android:layout_width="150dp"
        android:layout_height="55dp"
        android:layout_marginBottom="30dp"
        android:fontFamily="@font/iceberg"
        android:text="HOME"
        android:textAllCaps="true"
        android:textColor="#3F51B5"
        android:textSize="20sp"
        app:backgroundTint="#FFFFFF"
        app:cornerRadius="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>