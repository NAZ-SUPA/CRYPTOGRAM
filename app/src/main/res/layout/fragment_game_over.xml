<?xml version="1.0" encoding="utf-8"?>
<!--
    Game Over Fragment Layout:
    - This overlay appears when the player loses the game (e.g., reaches the maximum mistake count).
    - Uses a semi-transparent black background (#B3000000) to dim the game scene behind it.
    - Set with high elevation to overlay all other UI components.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#B3000000"
    android:clickable="true"
    android:focusable="true"
    android:elevation="20dp"
    tools:context=".GameOver">

    <!--
        Game Over Dialog Container:
        - Houses the failure message and navigation buttons.
        - Uses the dark theme (#303240) to match the game's overall design.
    -->
    <LinearLayout
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#303240"
        android:padding="32dp"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!--
            Game Over Title:
            - Large red text to indicate failure.
            - Styled with 'Iceberg' font.
        -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GAME OVER"
            android:textColor="#FF4C4C"
            android:textSize="36sp"
            android:fontFamily="@font/iceberg"
            android:layout_marginBottom="32dp" />

        <!--
            Restart Button:
            - Allows the player to try the level again immediately.
            - Click logic in GameOver.java includes a heart check.
        -->
        <Button
            android:id="@+id/btn_replay"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="RESTART"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#4CAF50"
            android:layout_marginBottom="16dp" />

        <!--
            Home Button:
            - Navigates the player back to the main menu.
        -->
        <Button
            android:id="@+id/btn_home_from_game_over"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="GO HOME"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#607D8B" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
