<?xml version="1.0" encoding="utf-8"?>
<!--
    HowToPlay modal layout logic:
    - Outer container acts as the dimmed overlay layer.
    - Inner white card contains instructional text and one explicit close action.
    - Content is resource-driven to keep wording centralized in strings.xml.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:background="#80000000"
    android:orientation="vertical">

    <!-- Instruction card surface: constrained width for readability on phones/tablets. -->
    <LinearLayout
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#FFFFFF">

        <!-- Title emphasizes purpose of this modal and maps to settings action label. -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_how_to_play"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <!-- Multi-line guidance bullet list explaining the intended gameplay loop. -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/how_to_play_instructions"
            android:textSize="16sp"/>

        <!-- Explicit dismissal control for users who do not use back gesture/button. -->
        <Button
            android:id="@+id/btnClose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:text="@string/btn_close"/>
    </LinearLayout>
</LinearLayout>