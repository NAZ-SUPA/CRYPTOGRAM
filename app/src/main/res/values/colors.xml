<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Global Color Palette Logic:
        - This file defines the primary, secondary, and accent colors for the CRYPTOGRAM brand.
        - Using semantic names (e.g., 'purple_main') ensures that changing the brand color
          only requires a single update here.
    -->

    <!-- Base Neutrals: Used for backgrounds, text, and divider lines. -->
    <color name="black">#FF000000</color>
    <color name="white">#FFFFFFFF</color>
    <color name="gray_light">#D9D9D9</color>
    <color name="bg_dark">#303240</color> <!-- The standard background for most activities -->

    <!-- Accent Colors: Used for highlights, CTA buttons, and error states. -->
    <color name="accent_yellow">#FFFB00</color> <!-- Used behind 'R' in the splash screen -->
    <color name="main_blue">#351FC5</color>    <!-- Primary color for 'PLAY' and 'LEVELS' labels -->
    <color name="error_red">#FF3434</color>     <!-- Color for the mistake tracking system -->

    <!-- Brand Purple Palette: Establishing the "Cryptogram" aesthetic. -->
    <color name="purple_light">#DBCAF2</color>
    <color name="purple_soft">#C8B3F6</color>
    <color name="purple_vibrant">#B681FF</color> <!-- Main text color for titles -->
    <color name="purple_main">#8947E4</color>
    <color name="purple_pinkish">#CE74F2</color>

    <!-- Supporting Palette: For decorative elements like category chips. -->
    <color name="mint_green">#97E3CC</color>
    <color name="bright_green">#9CE270</color>
</resources>