<resources>
    <!--
        App Design System & Theming Configuration:
        - This file defines the global visual language and component styles for the CRYPTOGRAM app.
        - Styles are organized by their functional role: Branding, Navigation, and Gameplay.
        - Implementing a centralized style system ensures visual consistency and facilitates global design updates.
    -->

    <!--
        Base Application Theme:
        - Inherits from Material3 DayNight with NoActionBar to allow for custom header implementations.
        - Provides the foundation for all activity themes in the project.
    -->
    <style name="Base.Theme.CRYPTOGRAM" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Baseline Material components configuration can be added here. -->
    </style>

    <!--
        Main Application Theme Alias:
        - The primary theme reference used in the AndroidManifest.xml.
    -->
    <style name="Theme.CRYPTOGRAM" parent="Base.Theme.CRYPTOGRAM" />

    <!--
        BRANDING STYLES:
        - These styles define the typography and colors for the splash screen and titles.
        - Establishing the "Welcome" and "Cryptogram" identity.
    -->

    <!-- Style for the "WELCOME TO" greeting text. -->
    <style name="welcome_to">
        <item name="android:textSize">35sp</item>
        <item name="android:textColor">@color/purple_vibrant</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Style for the main "CRYPTOGRAM" title logo. -->
    <style name="cryptogram">
        <item name="android:textSize">48sp</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:textColor">@color/purple_vibrant</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Style for the decorative cipher numeric pattern shown on the splash screen. -->
    <style name="cipher_style">
        <item name="android:textSize">25sp</item>
        <item name="android:textColor">@color/purple_vibrant</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

    <!--
        MENU & NAVIGATION STYLES:
        - These styles apply to category chips and primary action buttons.
        - Use high-contrast color pairings (e.g., Black/White/Blue) for accessibility and clarity.
    -->

    <!-- Base style for category labels (e.g., "FOCUS"). -->
    <style name="focus">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:fontFamily">@font/iceberg</item>
    </style>

    <!-- Inherited styles for specific categories. -->
    <style name="english" parent="focus" />
    <style name="puzzle" parent="focus" />

    <!-- Style for primary action text (e.g., "PLAY"). -->
    <style name="play">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/main_blue</item>
        <item name="android:fontFamily">@font/iceberg</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Style for the "LEVELS" navigation text. -->
    <style name="levels" parent="play" />

    <!--
        GAMEPLAY UI STYLES:
        - Specialized styles for the in-game experience, including mistake tracking and the keyboard.
    -->

    <!-- Style for the "MISTAKES" label; uses red to indicate a warning/penalty state. -->
    <style name="mistakes">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/error_red</item>
        <item name="android:fontFamily">@font/iceberg</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <!--
        Custom In-App Keyboard Key Style:
        - Defines a uniform grid layout for the custom QWERTY keyboard.
        - Uses a custom background drawable and weight-based sizing for consistency.
    -->
    <style name="KeyboardKey">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:background">@drawable/key_background_bold</item>
        <!-- backgroundTint is set to null to prevent the default Material theme from overriding the custom drawable. -->
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">0dp</item>
    </style>

    <!--
        General UI Status Style:
        - Used for labels like "FULL" in the heart system.
    -->
    <style name="full">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">@font/inter_bold</item>
    </style>

</resources>
